{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "image": {
      "type": "string",
      "metadata": {
        "description": "Full image reference, e.g. myacr.azurecr.io/solpbc:latest. Must be concrete at policy-generation time — the CCE policy pins its layers."
      }
    },
    "registryUsername": {
      "type": "string",
      "metadata": {
        "description": "ACR pull username (admin user, or a scoped-token name). ACR does not allow anonymous pull."
      }
    },
    "registryPassword": {
      "type": "securestring",
      "metadata": {
        "description": "ACR pull password/token. Not part of the CCE policy."
      }
    },
    "nonceHex": {
      "type": "string",
      "metadata": {
        "description": "Verifier nonce bound into REPORT_DATA at startup (32 or 64 bytes hex). Deliberately absent from the policy-generation params file so confcom wildcards the env value; supply it at deployment time only."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "solpbc",
      "location": "[resourceGroup().location]",
      "properties": {
        "sku": "Confidential",
        "confidentialComputeProperties": {
          "ccePolicy": ""
        },
        "osType": "Linux",
        "restartPolicy": "Never",
        "imageRegistryCredentials": [
          {
            "server": "[first(split(parameters('image'), '/'))]",
            "username": "[parameters('registryUsername')]",
            "password": "[parameters('registryPassword')]"
          }
        ],
        "containers": [
          {
            "name": "solpbc",
            "properties": {
              "image": "[parameters('image')]",
              "command": [
                "/bin/sh",
                "-c",
                "python3 /app/fetch-report.py ${NONCE_HEX:+--nonce-hex \"$NONCE_HEX\"} --out /tmp/report.bin; exec sleep infinity"
              ],
              "environmentVariables": [
                { "name": "NONCE_HEX", "value": "[parameters('nonceHex')]" }
              ],
              "resources": {
                "requests": { "cpu": 1, "memoryInGB": 2 }
              }
            }
          }
        ]
      }
    }
  ]
}
